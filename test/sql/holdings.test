# name: test/sql/holdings.test
# description: jpmorgan.holdings base table — fund_ticker partition (pushdown), current-only (no time travel).
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'jpmorgan' AS jpm (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='jpm.main';

# --- Schema: DESCRIBE binds only (no network). `holdings` is a base TABLE. ---

query T
SELECT string_agg(column_name, ',') FROM (DESCRIBE SELECT * FROM jpm.holdings WHERE fund_ticker = 'JEPI');
----
fund_ticker,as_of_date,name,ticker,cusip,weight_percent,market_value,shares,sec_type,sector,industry,country,currency,coupon_percent,maturity_date,rating,yield_percent

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM jpm.holdings WHERE fund_ticker = 'JEPI') WHERE column_name = 'as_of_date';
----
DATE

# --- Live invariants (hit J.P. Morgan). ---

# Partition pushdown: WHERE fund_ticker = 'JEPI' fetches that fund's holdings, weight-descending.
query I
SELECT (count(*) > 50 AND max(weight_percent) > 0 AND bool_and(fund_ticker = 'JEPI'))::INT
FROM jpm.holdings WHERE fund_ticker = 'JEPI';
----
1

# Every row of a fund carries the same reported as-of date.
query I
SELECT (count(DISTINCT as_of_date) = 1 AND max(as_of_date) IS NOT NULL)::INT
FROM jpm.holdings WHERE fund_ticker = 'JEPI';
----
1

# Multiple partitions at once: fund_ticker IN (...) fans out to two funds.
query I
SELECT (count(DISTINCT fund_ticker) = 2)::INT FROM jpm.holdings WHERE fund_ticker IN ('JEPI', 'JPST');
----
1

# An unfiltered scan streams EVERY fund's holdings (one partition per fund). LIMIT short-circuits
# the stream after the first partition, so this stays cheap (no full fan-out).
query I
SELECT (count(*) >= 1)::INT FROM (SELECT * FROM jpm.holdings LIMIT 5);
----
1

# The backing scan function also works directly (pushdown). It is listed under the same name as the
# `holdings` table it backs, so it is called with parens: holdings().
query I
SELECT (count(*) > 50)::INT FROM jpm.holdings() WHERE fund_ticker = 'JEPI';
----
1
