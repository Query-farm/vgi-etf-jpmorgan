# name: test/sql/products.test
# description: jpmorgan.products — base table: typed schema (network-free) + live catalog invariants.
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'jpmorgan' AS jpm (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='jpm.main';

# --- Schema: DESCRIBE binds only (no network), so these are fully deterministic. ---
# `products` is a base TABLE — query it with no parentheses.

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM jpm.products) WHERE column_name = 'ticker';
----
VARCHAR

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM jpm.products) WHERE column_name = 'net_assets';
----
DOUBLE

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM jpm.products) WHERE column_name = 'inception_date';
----
DATE

# --- Live invariants: these hit J.P. Morgan. Assert shape, not exact (moving) values. ---

# The catalog has many ETFs.
query I
SELECT (count(*) > 40)::INT FROM jpm.products;
----
1

# JEPI (JPMorgan Equity Premium Income ETF) is present with a positive NAV — via a WHERE.
query I
SELECT (count(*) = 1 AND max(nav) > 0)::INT FROM jpm.products WHERE ticker = 'JEPI';
----
1

# Both equity and fixed-income ETFs are represented.
query I
SELECT (count(DISTINCT asset_class) >= 2)::INT FROM jpm.products;
----
1
